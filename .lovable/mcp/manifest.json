        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Nº de transações (padrão 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "admin_overview",
        "title": "Overview admin",
        "description": "Retorna totais gerais da plataforma: nº de empresas, divulgadores, clientes, ofertas ativas, leads, cupons e saques pendentes. Apenas para usuários com papel ADMIN.",
