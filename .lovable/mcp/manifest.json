    "tools": [
      {
        "name": "whoami",
        "title": "Quem sou eu",
        "description": "Retorna o perfil do usuário logado no Clilin: id, nome, papel (CLIENT/COMPANY/AFFILIATE/ADMIN), cidade e saldo em centavos.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
